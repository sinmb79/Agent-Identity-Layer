{
  "name": "ail-nft-contracts",
  "version": "0.1.0",
  "description": "AIL Identity ERC-721 smart contracts",
  "private": true,
  "scripts": {
    "compile":        "hardhat compile",
    "test":           "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network base-sepolia",
    "deploy:achievement:testnet": "hardhat run scripts/deploy-achievement.js --network base-sepolia",
    "deploy:base":    "hardhat run scripts/deploy.js --network base",
    "deploy:achievement:base": "hardhat run scripts/deploy-achievement.js --network base",
    "deploy:polygon": "hardhat run scripts/deploy.js --network polygon",
    "deploy:bnb":     "hardhat run scripts/deploy.js --network bnb",
    "deploy:world":   "hardhat run scripts/deploy.js --network worldchain",
    "set-minter":     "hardhat run scripts/set-minter.js",
    "set-achievement-minter": "hardhat run scripts/set-achievement-minter.js"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.4.0"
  }
}
