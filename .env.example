# ── AIL Server ──────────────────────────────────────────────────────────────
# Master key for JWT signing (generate with: npm run setup:master-key)
AIL_MASTER_KEY_FILE=data/master-key.json

# SQLite database path (default: data/ail.db)
# AIL_DB_PATH=/data/ail.db

# Public server URL (used in NFT metadata URIs)
AIL_BASE_URL=https://ail.22blabs.ai

# ── On-chain NFT (optional — omit to run in off-chain/JWT-only mode) ─────────
# JSON-RPC endpoint (Alchemy recommended)
CHAIN_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Minter wallet private key (must match the minter address set on the contract)
CHAIN_PRIVATE_KEY=0x_your_minter_private_key_here

# Deployed AILIdentity contract address
NFT_CONTRACT_ADDRESS=0x4eeAD61dF800fcfA7a9F698f811a855389F74b6C

# ── Email (optional) ─────────────────────────────────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# EMAIL_FROM=noreply@22blabs.ai
